# Bez DATABASE_URL se použije lokální SQLite (vývoj).
#
# Supabase (cloud): vlož connection string ze Session pooleru (port 5432).
# Stačí ho vložit syrový, driver se doplní automaticky. Heslo nahraď svým.
# DATABASE_URL=postgresql://postgres.<project-ref>:<heslo>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# REDIS_URL=redis://localhost:6379/0

# Interval pollingu Garmin LiveTrack (sekundy)
LIVETRACK_POLL_SECONDS=30

# Strava OAuth (historie běžce pro osobní kalibraci, volitelné)
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=

# Přihlašovací e-maily přes Gmail (SMTP). SMTP_PASSWORD = heslo aplikace z Google.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=vas-gmail@gmail.com
# SMTP_PASSWORD=

# CORS pro frontend
FRONTEND_ORIGIN=http://localhost:3000

# Allowlist: kdo se smí přihlásit (oddělené čárkou). Prázdné = kdokoli.
# ALLOWED_EMAILS=vy@example.com,kolega@example.com
